# ── Application ────────────────────────────────────────────────────
APP_NAME=SentinelStream
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
API_V1_STR=/api/v1

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_KEY_TOO_MUST_BE_VERY_LONG
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_secret
POSTGRES_DB=sentinelstream
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret@db:5432/sentinelstream

# ── Redis ──────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0

# ── RabbitMQ ───────────────────────────────────────────────────────
RABBITMQ_USER=sentinel
RABBITMQ_PASSWORD=rabbit_secret
CELERY_BROKER_URL=amqp://sentinel:rabbit_secret@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/1

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# ── ML Model ───────────────────────────────────────────────────────
ML_MODEL_PATH=ml_models/isolation_forest.joblib
ML_SCALER_PATH=ml_models/scaler.joblib
FRAUD_SCORE_THRESHOLD=0.65

# ── Email (Webhook Alerts) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=alerts@sentinelstream.com
ALERT_EMAIL_TO=fraud_team@yourbank.com

# ── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
